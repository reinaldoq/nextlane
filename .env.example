# --- api (Vercel env vars in prod; local dev uses supabase start values) ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
# --- web (Vite build-time) — NOTE: Vite only reads env from web/, so these
# --- live in web/.env.local (gitignored); this file just documents them ---
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<from `supabase start` output>
# --- scripts only, NEVER deployed, NEVER in CI ---
SUPABASE_SERVICE_ROLE_KEY=<local/hosted service role key>
