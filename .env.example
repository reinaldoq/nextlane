# This repo's `.env` is auto-loaded by `just` (`set dotenv-load := true` in
# the justfile) AND by the `rails` CLI itself (`RailsConfig.load()` reads
# `<repo_root>/.env` on every invocation) -- so `uv run rails ...` works the
# same whether or not it's run through a `just` recipe. A key already set in
# the real environment always wins over the `.env` file's value. CI never
# reads this file at all -- CI sets real env vars directly.
# --- api (Vercel env vars in prod; local dev uses supabase start values) ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
# Optional: per-instance connection pool ceiling (api/_lib/db.py). Defaults to 5.
DB_POOL_MAX_SIZE=5
# --- web (Vite build-time) — NOTE: Vite only reads env from web/, so these
# --- live in web/.env.local (gitignored); this file just documents them ---
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<from `supabase start` output>
# --- scripts only, NEVER deployed, NEVER in CI ---
SUPABASE_SERVICE_ROLE_KEY=<local/hosted service role key>
